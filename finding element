public class Main{
    public static void main(String[] args){
        int[] arr={1,2,3,4};
        int target=5;
        boolean found=false;
        for(int i=0;i<arr.length;i++){
            if(arr[i]==target){
                found=true;
                break;
            }
        }if(found){
            System.out.println("element found");
        }else{
            System.out.println("element not found");
        }
    }
}
