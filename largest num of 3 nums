public class Main{
    public static int check(int a,int b,int c){
        if(a>b && a>c){
            return a;
        }else if(b>a && b>c){
            return b;
        }else{
            return c;
        }
    }
    public static void main(String[] args){
        int result=check(56,20,7);
        System.out.println(result);
    }
}
